---
import { getCollection } from "astro:content";
import SidebarFilter from "./sidebar-filter";
import type { SidebarSection } from "./sidebar-filter";

interface Props {
  currentPath?: string;
}

const { currentPath = "" } = Astro.props;

const commands = await getCollection("claudeCommands");
const skills = await getCollection("claudeSkills");
const agents = await getCollection("claudeAgents");
const claudeMds = await getCollection("claudeMd");

commands.sort((a, b) => a.id.localeCompare(b.id));
skills.sort((a, b) => a.id.localeCompare(b.id));
agents.sort((a, b) => a.id.localeCompare(b.id));
claudeMds.sort((a, b) => {
  if (a.id === "root") return -1;
  if (b.id === "root") return 1;
  return a.data.displayPath.localeCompare(b.data.displayPath);
});

const sections: SidebarSection[] = [];

if (claudeMds.length > 0) {
  sections.push({
    key: "claudemd",
    label: "CLAUDE.md",
    items: claudeMds.map((md) => ({
      id: md.id,
      label: md.data.displayPath,
      href: `/claudemd/${md.id}`,
    })),
  });
}

if (commands.length > 0) {
  sections.push({
    key: "commands",
    label: "Commands",
    items: commands.map((cmd) => ({
      id: cmd.id,
      label: `/${cmd.data.name || cmd.id}`,
      href: `/commands/${cmd.id}`,
    })),
  });
}

if (skills.length > 0) {
  sections.push({
    key: "skills",
    label: "Skills",
    items: skills.map((skill) => ({
      id: skill.id,
      label: skill.data.name || skill.id,
      href: `/skills/${skill.id}`,
    })),
  });
}

if (agents.length > 0) {
  sections.push({
    key: "agents",
    label: "Agents",
    items: agents.map((agent) => ({
      id: agent.id,
      label: agent.data.name || agent.id,
      href: `/agents/${agent.id}`,
    })),
  });
}
---

<SidebarFilter sections={sections} currentPath={currentPath} client:load />
