---
import { getCollection } from "astro:content";
import Layout from "@/layouts/layout.astro";

const agents = await getCollection("claudeAgents");
agents.sort((a, b) => a.id.localeCompare(b.id));
---

<Layout title="Agents" currentPath="/agents">
  <article class="content">
    <h1>Agents ({agents.length})</h1>
    <p>Global Claude Code subagents from <code>~/.claude/agents/</code>.</p>
    <ul>
      {agents.map((agent) => (
        <li>
          <a href={`/agents/${agent.id}`}>{agent.data.name || agent.id}</a>
          {agent.data.model && (
            <code class="text-caption ml-hsp-xs">{agent.data.model}</code>
          )}
          {agent.data.description && (
            <span class="text-muted"> -- {agent.data.description}</span>
          )}
        </li>
      ))}
    </ul>
  </article>
</Layout>
