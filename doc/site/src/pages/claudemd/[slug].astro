---
import { getCollection } from "astro:content";
import Layout from "@/layouts/layout.astro";
import { renderMarkdown } from "@/utils/render-markdown";
import { extractHeadings } from "@/utils/extract-headings";

export async function getStaticPaths() {
  const claudeMds = await getCollection("claudeMd");
  return claudeMds.map((entry) => ({
    params: { slug: entry.id },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const html = renderMarkdown(entry.body);
const headings = extractHeadings(entry.body || "");
const title = entry.data.displayPath;
---

<Layout title={title} currentPath={`/claudemd/${entry.id}`} headings={headings}>
  <article class="content">
    <h1>{title}</h1>
    <p class="text-muted">Path: <code>~/.claude/{entry.data.relPath}</code></p>
    <hr />
    <div set:html={html} />
  </article>
</Layout>
