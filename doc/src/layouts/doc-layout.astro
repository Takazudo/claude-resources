---
import "@/styles/global.css";
import Header from "@/components/header.astro";
import Sidebar from "@/components/sidebar.astro";
import { Toc } from "@/components/toc";
import { MobileToc } from "@/components/mobile-toc";
import ColorSchemeProvider from "@/components/color-scheme-provider.astro";
import CodeBlockEnhancer from "@/components/code-block-enhancer.astro";
import TabsInit from "@/components/tabs-init.astro";
import MermaidInit from "@/components/mermaid-init.astro";
import PageLoadingOverlay from "@/components/page-loading-overlay.astro";
import { ClientRouter } from "astro:transitions";
import { settings } from "@/config/settings";
import type { Heading } from "@/types/heading";
import { getNavSectionForSlug } from "@/utils/nav-scope";
import { defaultLocale, t, type Locale } from "@/config/i18n";
import { withBase } from "@/utils/base";
import Footer from "@/components/footer.astro";
import DesktopSidebarToggle from "@/components/desktop-sidebar-toggle";

interface Props {
  title: string;
  description?: string;
  lang?: Locale;
  currentSlug?: string;
  headings?: Heading[];
  unlisted?: boolean;
  hideSidebar?: boolean;
  hideToc?: boolean;
}

const {
  title,
  description,
  lang = defaultLocale,
  currentSlug,
  headings = [],
  unlisted = false,
  hideSidebar = false,
  hideToc = false,
} = Astro.props;
const fullTitle = title === settings.siteName ? title : `${title} | ${settings.siteName}`;
const navSection = currentSlug ? getNavSectionForSlug(currentSlug) : undefined;
const currentPath = Astro.url.pathname;
const contentAnim = {
  old: {
    name: "contentFadeOut",
    duration: 0,
    easing: "ease-in",
    fillMode: "both",
  },
  new: {
    name: "contentFadeIn",
    duration: 300,
    easing: "ease-out",
    fillMode: "both",
  },
};
const contentTransition = {
  forwards: contentAnim,
  backwards: contentAnim,
};
const htmlColorAttrs = settings.colorMode
  ? { "data-theme": settings.colorMode.defaultMode, style: `color-scheme: ${settings.colorMode.defaultMode}` }
  : { style: "color-scheme: dark" };
---

<html lang={lang} {...htmlColorAttrs}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{fullTitle}</title>
    {description && <meta name="description" content={description} />}
    <meta name="robots" content="noindex, nofollow" />
    <meta property="og:title" content={fullTitle} />
    {description && <meta property="og:description" content={description} />}
    <ColorSchemeProvider />
    {settings.sidebarResizer && (
      <script is:inline>
        (function () {
          function applySidebarWidth() {
            try {
              var w = localStorage.getItem("zudo-doc-sidebar-width");
              if (w && !isNaN(Number(w))) document.documentElement.style.setProperty("--zd-sidebar-w", w + "px");
            } catch (e) {}
          }
          applySidebarWidth();
          if (!window.__zdSidebarWidthApplied) {
            document.addEventListener("astro:after-swap", applySidebarWidth);
            window.__zdSidebarWidthApplied = true;
          }
        })();
      </script>
    )}
    {settings.sidebarToggle && (
      <script is:inline>
        (function () {
          function applySidebarState() {
            var stored; try { stored = localStorage.getItem("zudo-doc-sidebar-visible"); } catch (e) {}
            if (stored === "false") {
              document.documentElement.setAttribute("data-sidebar-hidden", "");
            } else {
              document.documentElement.removeAttribute("data-sidebar-hidden");
            }
          }
          applySidebarState();
          if (!window.__zdSidebarApplied) {
            document.addEventListener("astro:after-swap", applySidebarState);
            window.__zdSidebarApplied = true;
          }
        })();
      </script>
    )}
    <ClientRouter />
  </head>
  <body class="min-h-screen antialiased">
    <Header lang={lang} currentPath={currentPath}>
      <Sidebar slot="sidebar" currentSlug={currentSlug} lang={lang} navSection={navSection} />
    </Header>

    {/* Desktop sidebar */}
    {!hideSidebar && (
      <aside
        id="desktop-sidebar"
        aria-label="Documentation sidebar"
        transition:persist={`sidebar-${lang}-${navSection ?? "default"}`}
        class="hidden lg:block fixed top-[3.5rem] left-0 z-30 w-[var(--zd-sidebar-w)] h-[calc(100vh-3.5rem)] overflow-y-auto bg-bg border-r border-muted pb-vsp-xl"
      >
        <Sidebar currentSlug={currentSlug} lang={lang} navSection={navSection} />
      </aside>
    )}
    {!hideSidebar && settings.sidebarToggle && (
      <DesktopSidebarToggle client:load transition:persist="desktop-sidebar-toggle" />
    )}

    <div class:list={[!hideSidebar && "lg:ml-[var(--zd-sidebar-w)]", !hideSidebar && settings.sidebarToggle && "zd-sidebar-content-wrapper"]}>
      <div class="flex min-h-[calc(100vh-3.5rem)] justify-center">
        <div class:list={[
          "flex w-full gap-[clamp(1.5rem,3vw,4rem)]",
          hideSidebar ? "max-w-[80rem]" : "max-w-[clamp(50rem,75vw,90rem)]",
        ]}>
          {/* Main content */}
          <main class="flex-1 min-w-0 px-hsp-xl py-vsp-xl lg:px-hsp-2xl lg:py-vsp-2xl" transition:animate={contentTransition}>
            <slot name="breadcrumb" />
            {!hideToc && <MobileToc headings={headings} title={t("toc.title", lang)} client:load />}
            <article class="zd-content max-w-none">
              <slot />
            </article>
          </main>

          {/* Table of contents */}
          {!hideToc && <Toc headings={headings} client:load />}
        </div>
      </div>
      <Footer />
    </div>
    <CodeBlockEnhancer />
    <TabsInit />
    {settings.mermaid && <MermaidInit />}
    <PageLoadingOverlay />
    <script>
      let _sidebarScrollTop = 0;
      document.addEventListener("astro:before-swap", () => {
        const el = document.getElementById("desktop-sidebar");
        if (el) _sidebarScrollTop = el.scrollTop;
      });
      document.addEventListener("astro:after-swap", () => {
        const el = document.getElementById("desktop-sidebar");
        if (el) el.scrollTop = _sidebarScrollTop;
      });
    </script>
    {settings.sidebarResizer && (
      <script>
        function initSidebarResizer() {
          const sidebar = document.getElementById("desktop-sidebar");
          if (!sidebar || sidebar.querySelector("[data-sidebar-resizer]")) return;

          const handle = document.createElement("div");
          handle.setAttribute("data-sidebar-resizer", "");
          Object.assign(handle.style, {
            position: "absolute",
            top: "0",
            right: "0",
            width: "6px",
            height: "100%",
            cursor: "col-resize",
            zIndex: "10",
            transition: "background 0.15s",
          });

          handle.addEventListener("mouseenter", () => {
            if (!dragging) handle.style.background = "var(--zd-accent, rgba(128,128,128,0.3))";
          });
          handle.addEventListener("mouseleave", () => {
            if (!dragging) handle.style.background = "";
          });

          let dragging = false;

          handle.addEventListener("pointerdown", (e: PointerEvent) => {
            e.preventDefault();
            handle.setPointerCapture(e.pointerId);
            dragging = true;
            handle.style.background = "var(--zd-accent, rgba(128,128,128,0.3))";
            document.documentElement.style.cursor = "col-resize";
            document.documentElement.style.userSelect = "none";

            const ghost = document.createElement("div");
            Object.assign(ghost.style, {
              position: "fixed",
              top: "0",
              width: "2px",
              height: "100vh",
              background: "var(--zd-accent, rgba(128,128,128,0.5))",
              pointerEvents: "none",
              zIndex: "9999",
            });
            const sidebarRect = sidebar!.getBoundingClientRect();
            const sidebarLeft = sidebarRect.left;
            ghost.style.left = (sidebarLeft + sidebarRect.width) + "px";
            document.body.appendChild(ghost);
            let targetWidth = 0;

            const onMove = (ev: PointerEvent) => {
              targetWidth = Math.max(192, Math.min(448, ev.clientX - sidebarLeft));
              ghost.style.left = (sidebarLeft + targetWidth) + "px";
            };

            const cleanup = () => {
              dragging = false;
              handle.style.background = "";
              document.documentElement.style.cursor = "";
              document.documentElement.style.userSelect = "";
              ghost.remove();
              handle.removeEventListener("pointermove", onMove);
              handle.removeEventListener("pointerup", onUp);
              handle.removeEventListener("pointercancel", onCancel);
              handle.removeEventListener("lostpointercapture", onCancel);
            };

            const onUp = (ev: PointerEvent) => {
              handle.releasePointerCapture(ev.pointerId);
              cleanup();
              if (targetWidth > 0) {
                document.documentElement.style.setProperty("--zd-sidebar-w", targetWidth + "px");
                try { localStorage.setItem("zudo-doc-sidebar-width", String(Math.round(targetWidth))); } catch (e) {}
              }
            };

            const onCancel = () => { cleanup(); };

            handle.addEventListener("pointermove", onMove);
            handle.addEventListener("pointerup", onUp);
            handle.addEventListener("pointercancel", onCancel);
            handle.addEventListener("lostpointercapture", onCancel);
          });

          sidebar.appendChild(handle);
        }

        initSidebarResizer();
        document.addEventListener("astro:after-swap", initSidebarResizer);
      </script>
    )}
  </body>
</html>
